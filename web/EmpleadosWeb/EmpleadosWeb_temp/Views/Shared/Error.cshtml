@model ErrorViewModel

@{
    // Título de la página
    ViewData["Title"] = "Error";
}

<div class="container mt-5">

    <!-- Título principal -->
    <h1 class="text-danger text-center">Error</h1>

    <!-- Mensaje -->
    <h2 class="text-danger text-center mb-4">
        Ocurrió un error al procesar la solicitud.
    </h2>

    <!-- Mostrar ID si existe -->
    @if (Model.ShowRequestId)
    {
        <div class="text-center">
            <p>
                <strong>Id de la solicitud:</strong>
                <code>@Model.RequestId</code>
            </p>
        </div>
    }

    <!-- Información adicional -->
    <div class="mt-4">

        <h4>Modo de desarrollo</h4>

        <p>
            Cambiar al entorno <strong>Development</strong> mostrará información más detallada del error.
        </p>

        <p>
            <strong>No se recomienda habilitar el modo Development en producción</strong>,
            ya que puede exponer información sensible.
        </p>

    </div>

</div>